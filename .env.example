# MindBank Configuration
# Copy this file to .env and edit

# Server
MB_PORT=8095
MB_LOG_LEVEL=info

# Database (PostgreSQL with pgvector)
MB_DB_DSN=postgres://mindbank:CHANGE_ME@localhost:5434/mindbank?sslmode=disable
MB_PG_PORT=5434
MB_POSTGRES_PASSWORD=CHANGE_ME

# Ollama (for local embeddings)
MB_OLLAMA_URL=http://localhost:11434
MB_EMBED_MODEL=nomic-embed-text

# API Key (leave empty to disable auth)
MB_API_KEY=

# Embedding settings
MB_EMBED_BATCH=10
MB_EMBED_CACHE_SIZE=5000
